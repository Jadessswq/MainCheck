# ─── Локальный сервер (Ollama) ────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Рекомендуется (2026): qwen2.5:32b — лучшее качество русского
# официально-делового стиля на CPU, без thinking-режима. После прогрева
# ответ за 5–30 с на типовой фрагмент.
# Альтернативы (быстрее, чуть слабее качество): qwen2.5:14b · gemma3:27b · mistral-small3.2:24b
# qwen3:30b-a3b НЕ рекомендуется: thinking-режим игнорирует think:false на этих весах,
# в ответе пишет рассуждения вместо правок (см. Инструкции/LOCAL_MODEL.md).
MODEL_NAME=qwen2.5:32b

# Потоков CPU. Оставить 4 ядра ОС.
# ВАЖНО на серверах с несколькими сокетами/NUMA-нодами: ставьте число ядер
# одного сокета (обычно 16), а не суммарное. Cross-NUMA трафик в Ollama
# тормозит инференс в 2–3 раза. Проверить: `lscpu | grep NUMA`.
NUM_THREADS=28

# Размер окна контекста (input + output в токенах). 4096 — стандарт qwen2.5,
# но если ваши тексты редко длиннее 2 КБ, оставьте 2048 — это даёт ~2×
# прирост скорости на CPU без потери качества.
OLLAMA_NUM_CTX=2048

# Жёсткий лимит длины ответа в токенах. Без лимита Ollama иногда
# генерирует длинные «развёрнутые» комментарии. 1024 (~3000 символов)
# с запасом покрывают типовой исправленный фрагмент + блок ===CHANGES===.
OLLAMA_NUM_PREDICT=1024

# Таймаут запроса к Ollama в секундах. Должен быть БОЛЬШЕ клиентского
# (Settings.xba GetTimeout, по умолчанию 250), иначе клиент успеет
# отвалиться раньше сервера. 300 с покрывает первую загрузку 30B-модели
# с диска (~90 с) плюс генерацию (~30 с) с большим запасом.
OLLAMA_TIMEOUT=300

# Прогревать модель при старте сервера: один минимальный chat-запрос,
# чтобы веса оказались в RAM ДО первого пользовательского запроса.
# True (по умолчанию) — рекомендуется. False — экономит RAM при старте,
# но первый пользовательский запрос будет медленнее на 30–90 с.
OLLAMA_WARMUP=true
# Таймаут самого прогрева. Если модель тяжёлая или диск медленный —
# увеличьте до 300+.
OLLAMA_WARMUP_TIMEOUT=180

# Сколько модель остаётся в RAM после ответа. Без этого 30B-модель
# выгружается и каждый следующий запрос ждёт ~30–90 с.
OLLAMA_KEEP_ALIVE=30m

# qwen3 по умолчанию пишет длинный <think>…</think> перед ответом
# (минуты вычислений). Для правки текста это лишнее — оставляем false.
# Установите true только если хотите получить полное reasoning от модели
# (требует Ollama ≥ 0.9).
OLLAMA_THINK=false

# ─── RAG (обучение на ведомственных документах) ───────────────
# Если true — каждый запрос обогащается контекстом из проиндексированных документов
RAG_ENABLED=false
RAG_STORE_DIR=data/rag_store
RAG_DOCS_DIR=data/docs
RAG_TOP_K=4
# Модель эмбеддингов для Ollama (ollama pull nomic-embed-text)
RAG_EMBED_MODEL=nomic-embed-text

# ─── Логирование ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=30

# ─── Аудит запросов ───────────────────────────────────────────
AUDIT_ENABLED=true
AUDIT_DB=logs/audit.sqlite
AUDIT_REDACT_TEXT=false
