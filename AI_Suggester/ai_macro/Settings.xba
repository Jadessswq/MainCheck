<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE script:module PUBLIC "-//OpenOffice.org//DTD OfficeDocument 1.0//EN" "module.dtd">
<script:module xmlns:script="http://openoffice.org/2000/script" script:name="Settings" script:language="StarBasic"><![CDATA[
' ═══════════════════════════════════════════════════
'  НАСТРОЙКИ AI SUGGESTER
'  Отредактируйте константы ниже и сохраните модуль.
'  Перезапускать LibreOffice не нужно — достаточно вызвать макрос ещё раз.
' ═══════════════════════════════════════════════════

' Список серверов через | (pipe). Перебираются по порядку при ошибке.
' Формат: протокол://адрес:порт/suggest
' По умолчанию — сначала локальный (быстрый/оффлайн),
' затем запасной облачный сервер.
Public Function GetServerList() As String
    GetServerList = "http://localhost:8000/suggest"
    ' Пример с fallback:
    ' GetServerList = "http://localhost:8000/suggest|https://ai.example.org/suggest"
End Function

' Адрес для /health (берётся первый сервер SERVER_LIST, /suggest → /health)
Public Function GetHealthList() As String
    GetHealthList = Replace(GetServerList(), "/suggest", "/health")
End Function

' Таймаут одного HTTP-запроса, секунд. Локальный qwen3:30b-a3b
' обычно отвечает за 10–40 с, поэтому ставим 120 с с запасом.
Public Function GetTimeout() As Integer
    GetTimeout = 120
End Function

' Размер контекста (символы), передаваемого вместе с выделением.
' 2000 — компромисс между точностью стиля и нагрузкой на модель.
Public Function GetContextSize() As Integer
    GetContextSize = 2000
End Function

' Применять исправления как отслеживаемые изменения (Track Changes).
' Если True: перед подстановкой макрос временно включает режим «Правка → Отслеживать изменения»,
' и пользователь может принять/отклонить каждую правку штатными средствами LibreOffice.
' Если False: текст заменяется напрямую (как было в v1.2).
Public Function GetUseTrackChanges() As Boolean
    GetUseTrackChanges = True
End Function

' Максимальное число пунктов в диалоге (остальные обрезаются).
Public Function GetMaxChanges() As Integer
    GetMaxChanges = 60
End Function

]]></script:module>
