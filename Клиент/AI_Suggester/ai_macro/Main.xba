<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE script:module PUBLIC "-//OpenOffice.org//DTD OfficeDocument 1.0//EN" "module.dtd">
<script:module xmlns:script="http://openoffice.org/2000/script" script:name="Main" script:language="StarBasic"><![CDATA[

' Разделители в ответе сервера
Const SEP_CORR    As String = "===CORRECTED==="
Const SEP_CHANGES As String = "===CHANGES==="
Const SEP_END     As String = "===END==="

' Связь «nIdx кнопки ?» → «text правила» для ActionListener’а.
' Listener вызывается вне ShowDiffDialog, поэтому расписываем
' тексты в module-level массив.
Public g_aRuleTexts() As String

' ═══════════════════════════════════════════════════
'  ТОЧКА ВХОДА
' ═══════════════════════════════════════════════════
Sub AISuggestSelection()
    On Error GoTo ErrorHandler

    Dim oDoc  As Object : oDoc  = ThisComponent
    Dim oSels As Object : oSels = oDoc.getCurrentSelection()
    If IsNull(oSels) Or IsEmpty(oSels) Then
        MsgBox "Выделите фрагмент текста перед запуском.", 64, "AI Suggester"
        Exit Sub
    End If

    Dim oSel  As Object : oSel  = oSels.getByIndex(0)
    Dim sText As String : sText = oSel.getString()
    If Trim(sText) = "" Then
        MsgBox "Выделенный фрагмент пустой.", 64, "AI Suggester"
        Exit Sub
    End If

    ' Контекст — N символов до выделения (по умолчанию 2000)
    Dim oCur As Object : oCur = oDoc.Text.createTextCursorByRange(oSel)
    oCur.gotoStart(True)
    Dim sCtx As String : sCtx = Right(oCur.getString(), Settings.GetContextSize())

    ' Временные файлы (Temp-папка не требует прав на запись в другие директории)
    Dim oPS  As Object : oPS = CreateUnoService("com.sun.star.util.PathSettings")
    Dim sTmp As String : sTmp = ConvertFromURL(oPS.Temp)
    Dim sSep As String : sSep = IIf(GetGUIType() = 1, "\", "/")
    Dim sT As String : sT = sTmp & sSep & "ai_input.txt"
    Dim sC As String : sC = sTmp & sSep & "ai_ctx.txt"
    Dim sO As String : sO = sTmp & sSep & "ai_output.txt"
    Dim sS As String : sS = sTmp & sSep & "ai_status.txt"

    WriteUTF8 sT, sText
    WriteUTF8 sC, sCtx
    If FileExists(sO) Then Kill sO
    If FileExists(sS) Then Kill sS

    ' Перебор серверов из Settings.GetServerList()
    Dim aServers() As String : aServers = Split(Settings.GetServerList(), "|")
    Dim sRaw As String : sRaw = ""
    Dim sLastErr As String : sLastErr = ""
    Dim bGot As Boolean : bGot = False
    Dim sUsedServer As String : sUsedServer = ""
    Dim iSrv As Integer, nTimeout As Integer
    nTimeout = Settings.GetTimeout()

    For iSrv = 0 To UBound(aServers)
        Dim sUrl As String : sUrl = Trim(aServers(iSrv))
        If sUrl = "" Then GoTo NextServer

        If FileExists(sO) Then Kill sO
        If FileExists(sS) Then Kill sS

        Dim sCmd As String
        If GetGUIType() = 1 Then
            ' Windows: curl + status в отдельный файл.
            ' ВАЖНО: на cmd.exe одинарный % внутри -w "%{http_code}" может
            ' трактоваться как переменная окружения и сворачиваться в пустую
            ' строку → ai_status.txt оказывается 0 байт. Удваиваем %% — cmd
            ' пропустит его в curl как одинарный %, и код вернётся корректно.
            sCmd = "/c curl.exe -s --max-time " & CStr(nTimeout) & _
                   " -F ""text=@" & sT & """ -F ""context=@" & sC & """ " & _
                   sUrl & " -o """ & sO & """ -w ""%%{http_code}"" > """ & sS & """"
            Shell "cmd.exe", 1, sCmd, True
        Else
            ' Linux/macOS
            sCmd = "curl -s --max-time " & CStr(nTimeout) & _
                   " -F 'text=@" & sT & "' -F 'context=@" & sC & "' " & _
                   sUrl & " -o '" & sO & "' -w '%{http_code}' > '" & sS & "'"
            Shell "/bin/sh", 1, "-c " & Chr(34) & sCmd & Chr(34), True
        End If

        ' Проверка HTTP-статуса
        Dim sHttp As String : sHttp = ""
        If FileExists(sS) Then sHttp = Trim(ReadUTF8(sS))

        If Not FileExists(sO) Then
            sLastErr = "Сервер " & sUrl & ": нет ответа (таймаут/сеть)"
            GoTo NextServer
        End If

        sRaw = Trim(ReadUTF8(sO))
        If sRaw = "" Then
            sLastErr = "Сервер " & sUrl & ": пустой ответ (HTTP " & sHttp & ")"
            GoTo NextServer
        End If

        ' HTTP != 2xx → пробовать следующий сервер.
        ' Пустой sHttp намеренно НЕ трактуется как ошибка: если -w не записал
        ' код (например, cmd.exe скушал %), то ответ всё равно валидируется
        ' дальше через маркеры ===CORRECTED===/===END=== в ParseResponse —
        ' невалидное тело отвалится там, валидное — успешно применится.
        If sHttp <> "" And Left(sHttp, 1) <> "2" Then
            ' Если тело содержит валидные маркеры — это всё-таки успешный
            ' ответ от сервера приложения (а 4xx/5xx «прилетел» от прокси
            ' или иного промежуточного звена). Принимаем тело как есть.
            If InStr(sRaw, SEP_CORR) > 0 And InStr(sRaw, SEP_END) > 0 Then
                ' fallthrough — считаем успехом
            Else
                sLastErr = "Сервер " & sUrl & ": HTTP " & sHttp & " · " & Left(sRaw, 120)
                GoTo NextServer
            End If
        End If

        ' Сервер вернул маркер ошибки
        If Left(sRaw, 6) = "ОШИБКА" Then
            sLastErr = "Сервер " & sUrl & ": " & Left(sRaw, 200)
            GoTo NextServer
        End If

        ' Успех
        bGot = True
        sUsedServer = sUrl
        Exit For

        NextServer:
    Next iSrv

    ' Очистка временных файлов запроса (ответ оставим для отладки при ошибке)
    If FileExists(sT) Then Kill sT
    If FileExists(sC) Then Kill sC

    If Not bGot Then
        Dim sErrMsg As String
        sErrMsg = "Все серверы недоступны." & Chr(10) & Chr(10) & _
                  "Последняя ошибка:" & Chr(10) & sLastErr & Chr(10) & Chr(10) & _
                  "Серверы из списка:" & Chr(10) & Join(aServers, Chr(10)) & Chr(10) & Chr(10) & _
                  "Повторить попытку?"
        If MsgBox(sErrMsg, 5+16, "AI Suggester") = 4 Then Call AISuggestSelection
        Exit Sub
    End If

    ' ═══ Парсинг ответа ═══
    Dim sCorrected As String
    Dim nMax As Integer : nMax = Settings.GetMaxChanges()
    Dim aChanges() As String : ReDim aChanges(nMax)
    Dim aOldFrags() As String : ReDim aOldFrags(nMax)
    Dim aNewFrags() As String : ReDim aNewFrags(nMax)
    Dim nChanges As Integer

    Dim bParsed As Boolean
    bParsed = ParseResponse(sRaw, sCorrected, aChanges(), aOldFrags(), aNewFrags(), nChanges)
    If Not bParsed Then
        ' Ответ пришёл, но без маркеров — показать как есть, без структурных правок.
        sCorrected = sRaw
        aChanges(0) = "Ответ сервера без структурных маркеров — проверка невозможна"
        aOldFrags(0) = "" : aNewFrags(0) = ""
        nChanges = 1
    End If

    ' Сколько из правок реально применимы как find/replace (есть и старое, и новое)
    Dim aSelected() As Boolean : ReDim aSelected(nMax)
    Dim nFrags As Integer : nFrags = 0
    Dim k As Integer
    For k = 0 To nChanges - 1
        aSelected(k) = True
        If aOldFrags(k) <> "" And aNewFrags(k) <> "" Then nFrags = nFrags + 1
    Next k

    ' Панели diff — берут «до/после» из тех же aOldFrags/aNewFrags
    Dim sBeforePanel As String, sAfterPanel As String
    BuildDiffPanels aOldFrags(), aNewFrags(), aChanges(), nChanges, sBeforePanel, sAfterPanel

    ' Диалог: пользователь выбирает (чекбоксы), какие правки применять
    If ShowDiffDialog(sBeforePanel, sAfterPanel, aChanges(), nChanges, aSelected()) Then
        ' Считаем, сколько правок отмечено после диалога — нужно для guard'а
        ' «не вызывать ApplyCorrection, если всё снято». Для выбора ветки
        ' (per-fragment vs whole-replace) использовать НЕЛЬЗЯ: ApplyCorrection
        ' получает nFrags (общее число распарсенных пар «старое/новое»), и
        ' ApplyPerFragment сам пропускает невыбранные через aSelected().
        ' Если передавать сюда «выбранные пары» — при сценарии «есть и пары
        ' и информационная строка, пользователь снял все пары» получим
        ' nSelected_pairs=0 → ApplyWholeReplace → всё выделение перезаписано.
        Dim nApply As Integer : nApply = 0
        Dim kk As Integer
        For kk = 0 To nChanges - 1
            If aSelected(kk) Then nApply = nApply + 1
        Next kk

        If nApply > 0 Then
            Dim sSkipped As String : sSkipped = ""
            ApplyCorrection oDoc, oSel, sCorrected, _
                            aOldFrags(), aNewFrags(), aSelected(), _
                            nChanges, nFrags, sSkipped

            If sSkipped <> "" Then
                MsgBox "Часть правок не удалось применить (фрагмент не найден " & _
                       "в выделении — текст уже отличается от того, что видел сервер):" & _
                       Chr(10) & Chr(10) & sSkipped, 48, "AI Suggester — отчёт"
            End If
        End If
    End If

    Exit Sub
ErrorHandler:
    MsgBox "Ошибка макроса (#" & Err & "): " & Error & Chr(10) & "Строка: " & Erl, 16, "AI Suggester"
End Sub


' ═══════════════════════════════════════════════════
'  ПРИМЕНЕНИЕ ИСПРАВЛЕНИЙ
' ═══════════════════════════════════════════════════
' Если у нас распарсены пары «старое»/«новое» — применяем поштучно
' (каждая правка = свой redline). Если пар нет (сервер вернул только
' CORRECTED, или пары не извлеклись) — fallback на whole-replace
' с сохранением разрывов абзацев и стиля.
'
' Если Settings.GetUseTrackChanges() = True, перед заменой включаем режим
' «Отслеживать изменения» (RecordChanges) — LibreOffice сам формирует
' redline-блоки, которые пользователь принимает/отклоняет через
' «Правка → Отслеживать изменения → Управление».
Sub ApplyCorrection(oDoc As Object, oSel As Object, sCorrected As String, _
                    aOldFrags() As String, aNewFrags() As String, _
                    aSelected() As Boolean, nChanges As Integer, _
                    nFrags As Integer, ByRef sSkipped As String)
    Dim bPrevRec As Boolean : bPrevRec = False
    Dim bShouldRestore As Boolean : bShouldRestore = False

    If Settings.GetUseTrackChanges() Then
        On Error Resume Next
        bPrevRec = CBool(oDoc.getPropertyValue("RecordChanges"))
        If Err = 0 Then
            oDoc.setPropertyValue("RecordChanges", True)
            bShouldRestore = True
        End If
        Err = 0
        On Error Goto 0
    End If

    If nFrags > 0 Then
        ApplyPerFragment oSel, aOldFrags(), aNewFrags(), aSelected(), nChanges, sSkipped
    Else
        ' Нет структурированных правок — применяем целиком, но аккуратно
        ApplyWholeReplace oSel, sCorrected
    End If

    If bShouldRestore Then
        On Error Resume Next
        oDoc.setPropertyValue("RecordChanges", bPrevRec)
        On Error Goto 0
    End If
End Sub


' Точечная замена каждой пары (sOld → sNew) внутри границ исходного выделения.
' Track Changes (если включён) фиксирует каждую правку отдельным redline,
' пользователь принимает/отклоняет каждую штатно.
Sub ApplyPerFragment(oSel As Object, _
                     aOldFrags() As String, aNewFrags() As String, _
                     aSelected() As Boolean, nChanges As Integer, _
                     ByRef sSkipped As String)
    Dim oTextObj As Object : oTextObj = oSel.getText()

    ' Запоминаем границы исходного выделения. XTextRange корректно
    ' переезжает по документу при правках, так что oRangeEnd останется
    ' валидным после каждой замены.
    Dim oRangeStart As Object : oRangeStart = oSel.getStart()
    Dim oRangeEnd   As Object : oRangeEnd   = oSel.getEnd()

    Dim i As Integer
    For i = 0 To nChanges - 1
        If Not aSelected(i) Then GoTo NextFrag
        Dim sOld As String : sOld = aOldFrags(i)
        Dim sNew As String : sNew = aNewFrags(i)
        If sOld = "" Then GoTo NextFrag

        ' Курсор по всему текущему выделению (после прошлых правок)
        Dim oCur As Object : oCur = oTextObj.createTextCursorByRange(oRangeStart)
        oCur.gotoRange(oRangeEnd, True)
        Dim sCurText As String : sCurText = oCur.getString()
        ' Writer возвращает в getString() разрыв абзаца как \r\n (2 символа),
        ' тогда как goRight() считает разрыв за 1 позицию. Без нормализации
        ' nPos завышается на число абзацев между началом выделения и найденным
        ' фрагментом → goRight промахивается → setString портит чужой текст.
        sCurText = Replace(sCurText, Chr(13), "")

        Dim nPos As Long : nPos = InStr(sCurText, sOld)
        If nPos = 0 Then
            sSkipped = sSkipped & "  • «" & Left(sOld, 80) & _
                       IIf(Len(sOld) > 80, "…", "") & "»" & Chr(10)
            GoTo NextFrag
        End If

        ' Курсор для замены: oRangeStart + (nPos-1) символов вправо,
        ' расширить вправо на Len(sOld) с зажатым shift, затем setString
        Dim oRepl As Object : oRepl = oTextObj.createTextCursorByRange(oRangeStart)
        oRepl.goRight(nPos - 1, False)
        oRepl.goRight(Len(sOld), True)
        oRepl.setString(sNew)

        NextFrag:
    Next i
End Sub


' Целиковая замена с сохранением разрывов абзацев и стиля.
' Используется ТОЛЬКО когда сервер не вернул структурированные пары.
' Делает: запоминает ParaStyleName начала выделения, удаляет содержимое,
' вставляет текст по строкам с настоящими PARAGRAPH_BREAK между ними.
Sub ApplyWholeReplace(oSel As Object, sText As String)
    ' Нормализуем переводы строк: всегда Chr(10)
    Dim sNorm As String
    sNorm = Replace(sText, Chr(13) & Chr(10), Chr(10))
    sNorm = Replace(sNorm, Chr(13), Chr(10))

    Dim oTextObj As Object : oTextObj = oSel.getText()

    ' Запоминаем стиль абзаца в стартовой позиции, чтобы восстановить его
    Dim sParaStyle As String : sParaStyle = ""
    On Error Resume Next
    Dim oStartCur As Object : oStartCur = oTextObj.createTextCursorByRange(oSel.getStart())
    sParaStyle = oStartCur.ParaStyleName
    On Error Goto 0

    ' Удаляем выделение
    oSel.setString("")

    ' Курсор в позицию удалённого выделения
    Dim oCur As Object : oCur = oTextObj.createTextCursorByRange(oSel.getStart())
    If sParaStyle <> "" Then
        On Error Resume Next
        oCur.ParaStyleName = sParaStyle
        On Error Goto 0
    End If

    Dim aParas() As String : aParas = Split(sNorm, Chr(10))
    Dim i As Integer
    For i = 0 To UBound(aParas)
        If i > 0 Then
            ' Разрыв абзаца, а не line break — иначе нумерация и стили
            ' не подхватятся для следующего параграфа.
            On Error Resume Next
            oTextObj.insertControlCharacter(oCur, _
                com.sun.star.text.ControlCharacter.PARAGRAPH_BREAK, False)
            On Error Goto 0
        End If
        oTextObj.insertString(oCur, aParas(i), False)
    Next i
End Sub


' ═══════════════════════════════════════════════════
'  ПАРСИНГ ОТВЕТА СЕРВЕРА
' ═══════════════════════════════════════════════════
' aChanges()  — полные строки правок (для UI и пояснений)
' aOldFrags() — фрагмент в «старое» (между Chr(171) и Chr(187), пара 1)
' aNewFrags() — фрагмент в «новое» (между Chr(171) и Chr(187), пара 2)
' Если в строке нет двух пар guillemets — фрагменты остаются пустыми;
' такая правка отображается, но не применяется автоматически.
Function ParseResponse(sRaw As String, sCorrected As String, _
                       aChanges() As String, aOldFrags() As String, _
                       aNewFrags() As String, nChanges As Integer) As Boolean
    Dim nP1 As Long : nP1 = InStr(sRaw, SEP_CORR)
    Dim nP2 As Long : nP2 = InStr(sRaw, SEP_CHANGES)
    Dim nP3 As Long : nP3 = InStr(sRaw, SEP_END)
    If nP1 = 0 Or nP2 = 0 Then ParseResponse = False : Exit Function
    If nP2 <= nP1 Then ParseResponse = False : Exit Function

    sCorrected = Trim(Mid(sRaw, nP1 + Len(SEP_CORR), nP2 - nP1 - Len(SEP_CORR)))

    Dim sChangeSec As String
    If nP3 > nP2 Then
        sChangeSec = Trim(Mid(sRaw, nP2 + Len(SEP_CHANGES), nP3 - nP2 - Len(SEP_CHANGES)))
    Else
        sChangeSec = Trim(Mid(sRaw, nP2 + Len(SEP_CHANGES)))
    End If

    Dim aLines() As String : aLines = Split(sChangeSec, Chr(10))
    nChanges = 0
    Dim nMax As Integer : nMax = UBound(aChanges)
    Dim i As Integer
    For i = 0 To UBound(aLines)
        Dim sLine As String : sLine = Trim(aLines(i))
        If Right(sLine, 1) = Chr(13) Then sLine = Left(sLine, Len(sLine) - 1)
        If sLine <> "" And Left(sLine, 3) <> "===" Then
            aChanges(nChanges) = sLine
            aOldFrags(nChanges) = ExtractBetweenGuillemets(sLine, 1)
            aNewFrags(nChanges) = ExtractBetweenGuillemets(sLine, 2)
            nChanges = nChanges + 1
            If nChanges >= nMax Then Exit For
        End If
    Next i

    If nChanges = 0 Then
        aChanges(0) = "Ошибок не найдено."
        aOldFrags(0) = "" : aNewFrags(0) = ""
        nChanges = 1
    End If
    ParseResponse = True
End Function


' ═══════════════════════════════════════════════════
'  ИЗВЛЕЧЕНИЕ ФРАГМЕНТОВ ДО/ПОСЛЕ ИЗ СПИСКА ИЗМЕНЕНИЙ
' ═══════════════════════════════════════════════════
Sub BuildDiffPanels(aOldFrags() As String, aNewFrags() As String, _
                    aChanges() As String, nChanges As Integer, _
                    sBefore As String, sAfter As String)
    sBefore = ""
    sAfter  = ""
    Dim i As Integer
    For i = 0 To nChanges - 1
        Dim sB As String : sB = aOldFrags(i)
        Dim sA As String : sA = aNewFrags(i)

        If sB <> "" Or sA <> "" Then
            Dim sN As String : sN = ""
            Dim sLine As String : sLine = aChanges(i)
            Dim nDot As Integer : nDot = InStr(sLine, ".")
            If nDot > 0 And nDot <= 3 Then sN = Left(sLine, nDot) & " "

            sBefore = sBefore & sN & IIf(sB <> "", sB, "—") & Chr(10)
            sAfter  = sAfter  & sN & IIf(sA <> "", sA, "—") & Chr(10)
        End If
    Next i

    If Trim(sBefore) = "" Then
        sBefore = "(нет изменений)"
        sAfter  = "(нет изменений)"
    End If
End Sub


Function ExtractBetweenGuillemets(sLine As String, nPair As Integer) As String
    ExtractBetweenGuillemets = ""
    Dim nOpen As Long : nOpen = 1
    Dim nFound As Integer : nFound = 0
    Do
        nOpen = InStr(nOpen, sLine, Chr(171))
        If nOpen = 0 Then Exit Function
        Dim nClose As Long : nClose = InStr(nOpen + 1, sLine, Chr(187))
        If nClose = 0 Then Exit Function
        nFound = nFound + 1
        If nFound = nPair Then
            ExtractBetweenGuillemets = Mid(sLine, nOpen + 1, nClose - nOpen - 1)
            Exit Function
        End If
        nOpen = nClose + 1
    Loop
End Function


' ═══════════════════════════════════════════════════
'  ДИАЛОГ С DIFF-ОТОБРАЖЕНИЕМ + ВЫБОРОМ ПРАВОК
' ═══════════════════════════════════════════════════
' Возвращает True, если пользователь нажал OK. aSelected() выставляется
' по итогам состояния каждого CheckBox (true = применить, false = пропустить).
' На вход aSelected() приходит со всеми True (по умолчанию все правки
' выбраны). Пользователь снимает галочки тех, что применять не нужно —
' клик по самому чекбоксу штатно переключает State (без модификаторов).
'
' Layout вычисляется динамически: при большом числе правок раскладываем
' в 2 колонки, чтобы дилог не вылезал за экран; при > 36 — в 3.
Function ShowDiffDialog(sBeforePanel As String, sAfterPanel As String, _
                        aChanges() As String, nChanges As Integer, _
                        aSelected() As Boolean) As Boolean
    ShowDiffDialog = False
    On Error GoTo DlgErr

    ' Геометрия
    Dim nW As Integer : nW = 340
    Dim nRowH As Integer : nRowH = 12
    Dim nCBStartY As Integer : nCBStartY = 122

    Dim nCols As Integer
    If nChanges <= 18 Then
        nCols = 1
    ElseIf nChanges <= 36 Then
        nCols = 2
    Else
        nCols = 3
    End If
    Dim nRowsPerCol As Integer
    nRowsPerCol = (nChanges + nCols - 1) \ nCols
    If nRowsPerCol < 1 Then nRowsPerCol = 1

    Dim nFooterH As Integer : nFooterH = 26   ' высота полосы с кнопками
    Dim nDlgH As Integer
    nDlgH = nCBStartY + nRowsPerCol * nRowH + nFooterH + 6

    Dim oMdl As Object : oMdl = CreateUnoService("com.sun.star.awt.UnoControlDialogModel")
    With oMdl
        .Width = nW : .Height = nDlgH
        .Title = "AI Suggester — Предложение по улучшению текста"
        .Closeable = True : .Moveable = True : .Sizeable = False
    End With

    ' Шапка
    Dim oHdr As Object : oHdr = oMdl.createInstance("com.sun.star.awt.UnoControlFixedTextModel")
    With oHdr
        .PositionX = 0 : .PositionY = 0 : .Width = nW : .Height = 14
        .Label = "  Найденные ошибки. Снимите галочки с тех правок, которые применять не нужно."
        .BackgroundColor = RGB(17, 78, 140) : .TextColor = RGB(255, 255, 255)
        .FontWeight = com.sun.star.awt.FontWeight.BOLD : .FontHeight = 11
    End With
    oMdl.insertByName("hdr", oHdr)

    ' Заголовки панелей diff
    Dim oL1 As Object : oL1 = oMdl.createInstance("com.sun.star.awt.UnoControlFixedTextModel")
    With oL1
        .PositionX = 6 : .PositionY = 17 : .Width = 158 : .Height = 9
        .Label = "  Исходные фрагменты с ошибками:"
        .BackgroundColor = RGB(255, 235, 220) : .TextColor = RGB(140, 40, 0)
        .FontWeight = com.sun.star.awt.FontWeight.BOLD : .FontHeight = 11
    End With
    oMdl.insertByName("l1", oL1)

    Dim oL2 As Object : oL2 = oMdl.createInstance("com.sun.star.awt.UnoControlFixedTextModel")
    With oL2
        .PositionX = 172 : .PositionY = 17 : .Width = 162 : .Height = 9
        .Label = "  Исправленные фрагменты:"
        .BackgroundColor = RGB(220, 245, 220) : .TextColor = RGB(0, 100, 0)
        .FontWeight = com.sun.star.awt.FontWeight.BOLD : .FontHeight = 11
    End With
    oMdl.insertByName("l2", oL2)

    Dim oT1 As Object : oT1 = oMdl.createInstance("com.sun.star.awt.UnoControlEditModel")
    With oT1
        .PositionX = 6 : .PositionY = 27 : .Width = 158 : .Height = 72
        .MultiLine = True : .ReadOnly = True : .VScroll = True : .HScroll = False
        .Text = sBeforePanel
        .Border = 1 : .BackgroundColor = RGB(255, 246, 238) : .FontHeight = 14
    End With
    oMdl.insertByName("t1", oT1)

    Dim oT2 As Object : oT2 = oMdl.createInstance("com.sun.star.awt.UnoControlEditModel")
    With oT2
        .PositionX = 172 : .PositionY = 27 : .Width = 162 : .Height = 72
        .MultiLine = True : .ReadOnly = True : .VScroll = True : .HScroll = False
        .Text = sAfterPanel
        .Border = 1 : .BackgroundColor = RGB(238, 255, 238) : .FontHeight = 14
    End With
    oMdl.insertByName("t2", oT2)

    ' Полоса со счётчиком над панелью правил.
    Dim oCnt As Object : oCnt = oMdl.createInstance("com.sun.star.awt.UnoControlFixedTextModel")
    Dim sMode As String : sMode = IIf(Settings.GetUseTrackChanges(), " · режим Track Changes", "")
    With oCnt
        .PositionX = 6 : .PositionY = 102 : .Width = nW - 12 : .Height = 9
        .Label = "Найдено правок: " & CStr(nChanges) & sMode & _
                 ". Нажмите «?» рядом с галочкой, чтобы прочитать пояснение."
        .TextColor = RGB(80, 80, 80) : .FontHeight = 11
        .FontWeight = com.sun.star.awt.FontWeight.BOLD
    End With
    oMdl.insertByName("cnt", oCnt)

    ' Чекбоксы — по штуке на правку; рядом с каждым — кнопка «?» с пояснением.
    ' Полный текст каждого правила складываем в g_aRuleTexts(),
    ' чтобы ActionListener мог до него дотянуться вне скоупа функции.
    ReDim g_aRuleTexts(nChanges - 1)

    Dim nColW As Integer : nColW = (nW - 12) \ nCols     ' ширина колонки
    Dim nHelpW As Integer : nHelpW = 12                  ' кнопка ? справа
    Dim nCBW As Integer : nCBW = nColW - nHelpW - 2      ' чекбокс перед ней
    Dim i As Integer
    For i = 0 To nChanges - 1
        Dim nCol As Integer : nCol = i Mod nCols
        Dim nRow As Integer : nRow = i \ nCols

        Dim sLine As String : sLine = aChanges(i)
        If sLine = "" Then sLine = "(пустая строка)"
        Dim sFull As String : sFull = sLine
        If Len(sLine) < 3 Or InStr(Left(sLine, 4), ".") = 0 Then
            sFull = CStr(i + 1) & ". " & sLine
        End If
        g_aRuleTexts(i) = sFull

        ' Подпись чекбокса — короткий «отпечаток» правки. Полный
        ' текст открывается кликом по «?» или в тултипе на неё.
        ' Обрезаем по реальной ёмкости колонки — иначе на Windows
        ' LibreOffice длинный label рендерится за пределы Width.
        Dim nMaxChars As Integer : nMaxChars = (nCBW - 14) \ 5
        If nMaxChars < 8 Then nMaxChars = 8
        Dim sLabel As String : sLabel = sFull
        If Len(sLabel) > nMaxChars Then sLabel = Left(sLabel, nMaxChars - 1) & "…"

        Dim oCB As Object : oCB = oMdl.createInstance("com.sun.star.awt.UnoControlCheckBoxModel")
        With oCB
            .PositionX = 6 + nCol * nColW
            .PositionY = nCBStartY + nRow * nRowH
            .Width = nCBW : .Height = nRowH - 1
            .Label = sLabel
            .HelpText = sFull
            .State = 1
            .TriState = False
            .FontHeight = 10
        End With
        oMdl.insertByName("cb_" & i, oCB)

        ' Кнопка «?» справа от чекбокса.
        Dim oHB As Object : oHB = oMdl.createInstance("com.sun.star.awt.UnoControlButtonModel")
        With oHB
            .PositionX = 6 + nCol * nColW + nCBW + 1
            .PositionY = nCBStartY + nRow * nRowH
            .Width = nHelpW : .Height = nRowH - 1
            .Label = "?"
            .HelpText = sFull
            .FontHeight = 9
            .BackgroundColor = RGB(220, 230, 250)
            .TextColor = RGB(40, 60, 120)
            .FontWeight = com.sun.star.awt.FontWeight.BOLD
        End With
        oMdl.insertByName("hb_" & i, oHB)
    Next i

    ' Кнопки — внизу, сразу под полем чекбоксов
    Dim nBtnY As Integer : nBtnY = nCBStartY + nRowsPerCol * nRowH + 4
    Dim oBtnOk As Object : oBtnOk = oMdl.createInstance("com.sun.star.awt.UnoControlButtonModel")
    With oBtnOk
        .PositionX = nW - 152 : .PositionY = nBtnY : .Width = 70 : .Height = 18
        .Label = "✓  Применить" : .PushButtonType = com.sun.star.awt.PushButtonType.OK
        .DefaultButton = True : .BackgroundColor = RGB(0, 110, 0) : .TextColor = RGB(255,255,255)
        .FontWeight = com.sun.star.awt.FontWeight.BOLD : .FontHeight = 11
    End With
    oMdl.insertByName("btnOk", oBtnOk)

    Dim oBtnCan As Object : oBtnCan = oMdl.createInstance("com.sun.star.awt.UnoControlButtonModel")
    With oBtnCan
        .PositionX = nW - 76 : .PositionY = nBtnY : .Width = 70 : .Height = 18
        .Label = "✗  Отклонить" : .PushButtonType = com.sun.star.awt.PushButtonType.CANCEL
        .BackgroundColor = RGB(160, 0, 0) : .TextColor = RGB(255,255,255) : .FontHeight = 11
    End With
    oMdl.insertByName("btnCan", oBtnCan)

    Dim oDlg As Object : oDlg = CreateUnoService("com.sun.star.awt.UnoControlDialog")
    oDlg.setModel(oMdl)
    Dim oTk As Object : oTk = CreateUnoService("com.sun.star.awt.Toolkit")
    oDlg.createPeer(oTk, StarDesktop.getCurrentFrame().getContainerWindow())

    ' Подписываемся на клики по кнопкам «?» — по клику покажем
    ' MsgBox с полным текстом правила (из g_aRuleTexts по индексу
    ' из имени контрола «hb_<i>»).
    Dim oHelpListener As Object
    oHelpListener = createUnoListener("HelpBtn_", "com.sun.star.awt.XActionListener")
    Dim k As Integer
    For k = 0 To nChanges - 1
        oDlg.getControl("hb_" & k).addActionListener(oHelpListener)
    Next k

    Dim nRes As Integer : nRes = oDlg.execute()

    ' Если пользователь нажал OK — забираем State каждого CheckBox.
    ' State: 0 = unchecked, 1 = checked, 2 = undetermined (не используем).
    If nRes = 1 Then
        Dim j As Integer
        For j = 0 To nChanges - 1
            aSelected(j) = (oDlg.getControl("cb_" & j).Model.State = 1)
        Next j
    End If

    oDlg.dispose()
    ShowDiffDialog = (nRes = 1)
    Exit Function
DlgErr:
    MsgBox "Ошибка диалога (#" & Err & "): " & Error, 16, "AI Suggester"
End Function


' ═══════════════════════════════════════════════════
'  I/O
' ═══════════════════════════════════════════════════
Sub WriteUTF8(sPath As String, sText As String)
    Dim oSFA  As Object : oSFA  = CreateUnoService("com.sun.star.ucb.SimpleFileAccess")
    Dim oPipe As Object : oPipe = CreateUnoService("com.sun.star.io.Pipe")
    Dim oOut  As Object : oOut  = CreateUnoService("com.sun.star.io.TextOutputStream")
    oOut.setOutputStream(oPipe) : oOut.setEncoding("UTF-8") : oOut.writeString(sText) : oOut.closeOutput()
    oSFA.writeFile(ConvertToURL(sPath), oPipe)
End Sub

Function ReadUTF8(sPath As String) As String
    Dim oSFA As Object : oSFA = CreateUnoService("com.sun.star.ucb.SimpleFileAccess")
    Dim oIn  As Object : oIn  = CreateUnoService("com.sun.star.io.TextInputStream")
    oIn.setInputStream(oSFA.openFileRead(ConvertToURL(sPath))) : oIn.setEncoding("UTF-8")
    Dim r As String : r = ""
    Do While Not oIn.isEOF() : r = r & oIn.readLine() & Chr(10) : Loop
    oIn.closeInput() : ReadUTF8 = r
End Function


' ═══════════════════════════════════════════════════
'  ActionListener для кнопок «?» в диалоге
' ═══════════════════════════════════════════════════
' XActionListener → два метода: actionPerformed + disposing.
' createUnoListener("HelpBtn_", "...XActionListener") вызывает Sub'ы
' с префиксом HelpBtn_ на эти события.
Sub HelpBtn_actionPerformed(oEvt As Object)
    On Error Resume Next
    Dim sName As String : sName = oEvt.Source.Model.Name   ' ожидаем "hb_<idx>"
    If Left(sName, 3) <> "hb_" Then Exit Sub
    Dim nIdx As Integer : nIdx = CInt(Mid(sName, 4))
    If nIdx < 0 Then Exit Sub
    If nIdx > UBound(g_aRuleTexts) Then Exit Sub
    MsgBox g_aRuleTexts(nIdx), 64, "AI Suggester — правило"
End Sub

Sub HelpBtn_disposing(oEvt As Object)
    ' Пусто— отписки от listener'а делать не нужно: диалог и все
    ' его контролы dispose'ятся вместе при выходе из ShowDiffDialog.
End Sub

]]></script:module>
