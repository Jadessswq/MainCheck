# ─── Облачный сервер (OpenRouter) ─────────────────────────────
# Получить бесплатный ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-ВАШ_КЛЮЧ_ЗДЕСЬ

# ─── HTTP-сервер ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Логирование ──────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=logs
# Сколько дней хранить лог-файлы и аудит-записи (0 = без ограничений)
LOG_RETENTION_DAYS=30

# ─── Аудит запросов (кто, когда, какой текст, сколько исправлений) ───
AUDIT_ENABLED=true
AUDIT_DB=logs/audit.sqlite
# Если true, полный текст запроса/ответа не сохраняется (только метрики)
AUDIT_REDACT_TEXT=false

# ─── Rate limit (запросов в минуту с одного IP, 0 = отключить) ───
RATE_LIMIT_RPM=60
