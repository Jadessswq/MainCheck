# ─── Локальный сервер (Ollama) ────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Рекомендуется (2026): Qwen3-30B-A3B-Instruct (MoE, быстро на CPU)
# Альтернативы: qwen2.5:32b · qwen2.5:14b · gemma3:27b · mistral-small3.2:24b
MODEL_NAME=qwen3:30b-a3b

# Потоков CPU (оставить 4 ядра ОС)
NUM_THREADS=28

# ─── RAG (обучение на ведомственных документах) ───────────────
# Если true — каждый запрос обогащается контекстом из проиндексированных документов
RAG_ENABLED=false
RAG_STORE_DIR=data/rag_store
RAG_DOCS_DIR=data/docs
RAG_TOP_K=4
# Модель эмбеддингов для Ollama (ollama pull nomic-embed-text)
RAG_EMBED_MODEL=nomic-embed-text

# ─── Логирование ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=30

# ─── Аудит запросов ───────────────────────────────────────────
AUDIT_ENABLED=true
AUDIT_DB=logs/audit.sqlite
AUDIT_REDACT_TEXT=false
