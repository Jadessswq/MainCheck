[Unit]
Description=AI LibreOffice Suggester — Local Server
After=network.target ollama.service

[Service]
Type=simple
User=YOUR_USERNAME
WorkingDirectory=/opt/ai-suggester
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
Environment="MODEL_NAME=qwen2.5:32b"
Environment="NUM_THREADS=28"

[Install]
WantedBy=multi-user.target
